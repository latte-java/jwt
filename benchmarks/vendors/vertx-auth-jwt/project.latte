jmhVersion   = "1.37"
vertxVersion = "4.5.14"

project(group: "org.lattejava.jwt.benchmarks", name: "vertx-auth-jwt-bench", version: "0.1.0", licenses: ["MIT"]) {
  workflow {
    standard()

    semanticVersions {
      // Netty uses a four-part .Final qualifier that Latte cannot parse without an explicit mapping.
      mapping(id: "io.netty:netty-bom:4.1.118.Final",                            version: "4.1.118")
      mapping(id: "io.netty:netty-buffer:4.1.118.Final",                          version: "4.1.118")
      mapping(id: "io.netty:netty-codec:4.1.118.Final",                           version: "4.1.118")
      mapping(id: "io.netty:netty-codec-dns:4.1.118.Final",                       version: "4.1.118")
      mapping(id: "io.netty:netty-codec-http:4.1.118.Final",                      version: "4.1.118")
      mapping(id: "io.netty:netty-codec-http2:4.1.118.Final",                     version: "4.1.118")
      mapping(id: "io.netty:netty-codec-socks:4.1.118.Final",                     version: "4.1.118")
      mapping(id: "io.netty:netty-common:4.1.118.Final",                          version: "4.1.118")
      mapping(id: "io.netty:netty-handler:4.1.118.Final",                         version: "4.1.118")
      mapping(id: "io.netty:netty-handler-proxy:4.1.118.Final",                   version: "4.1.118")
      mapping(id: "io.netty:netty-parent:4.1.118.Final",                          version: "4.1.118")
      mapping(id: "io.netty:netty-resolver:4.1.118.Final",                        version: "4.1.118")
      mapping(id: "io.netty:netty-resolver-dns:4.1.118.Final",                    version: "4.1.118")
      mapping(id: "io.netty:netty-transport:4.1.118.Final",                       version: "4.1.118")
      mapping(id: "io.netty:netty-transport-native-epoll:4.1.118.Final",          version: "4.1.118")
      mapping(id: "io.netty:netty-transport-native-kqueue:4.1.118.Final",         version: "4.1.118")
      mapping(id: "io.netty:netty-transport-native-unix-common:4.1.118.Final",    version: "4.1.118")
      // javassist 3.28.0-GA has a -GA qualifier and also a version-range JUnit test dep.
      mapping(id: "org.javassist:javassist:3.28.0-GA",                            version: "3.28.0")
      // jboss-vfs 3.2.15.Final comes via reflections (transitive of mockito via vertx-unit).
      mapping(id: "org.jboss:jboss-vfs:3.2.15.Final",                             version: "3.2.15")

      rangeMapping(id: "junit:junit:[4.13.1,)", version: "4.13.2")
    }
  }

  dependencies {
    group(name: "compile") {
      dependency(id: "io.vertx:vertx-auth-common:${vertxVersion}")
      dependency(id: "io.vertx:vertx-auth-jwt:${vertxVersion}")
      dependency(id: "io.vertx:vertx-core:${vertxVersion}")
      dependency(id: "org.lattejava.jwt.benchmarks:harness:0.1.0-{integration}")
      dependency(id: "org.openjdk.jmh:jmh-core:${jmhVersion}")
      dependency(id: "org.openjdk.jmh:jmh-generator-annprocess:${jmhVersion}")
    }
  }

  publications { standard() }
}

dependency = loadPlugin(id: "org.lattejava.plugin:dependency:0.1.5")
java       = loadPlugin(id: "org.lattejava.plugin:java:0.1.8")
idea       = loadPlugin(id: "org.lattejava.plugin:idea:0.1.5")

java.settings.javaVersion = "21"

target(name: "clean") { java.clean() }
target(name: "build") { java.compileMain(); java.jar() }
