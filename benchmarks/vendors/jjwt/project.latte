jjwtVersion = "0.12.6"
jmhVersion  = "1.37"

project(group: "org.lattejava.jwt.benchmarks", name: "jjwt-bench", version: "0.1.0", licenses: ["MIT"]) {
  workflow {
    standard()

    semanticVersions {
      // jjwt-jackson 0.12.6 depends on jackson-databind 2.12.7.1 (four-part version).
      mapping(id: "com.fasterxml.jackson.core:jackson-databind:2.12.7.1", version: "2.12.7")
      mapping(id: "com.fasterxml.jackson.core:jackson-annotations:2.12.7", version: "2.12.7")
      mapping(id: "com.fasterxml.jackson.core:jackson-core:2.12.7", version: "2.12.7")
    }
  }

  dependencies {
    group(name: "compile") {
      dependency(id: "io.jsonwebtoken:jjwt-api:${jjwtVersion}")
      dependency(id: "io.jsonwebtoken:jjwt-impl:${jjwtVersion}")
      dependency(id: "io.jsonwebtoken:jjwt-jackson:${jjwtVersion}")
      dependency(id: "org.lattejava.jwt.benchmarks:harness:0.1.0-{integration}")
      dependency(id: "org.openjdk.jmh:jmh-core:${jmhVersion}")
      dependency(id: "org.openjdk.jmh:jmh-generator-annprocess:${jmhVersion}")
    }
  }

  publications { standard() }
}

dependency = loadPlugin(id: "org.lattejava.plugin:dependency:0.1.5")
java       = loadPlugin(id: "org.lattejava.plugin:java:0.1.8")
idea       = loadPlugin(id: "org.lattejava.plugin:idea:0.1.5")

java.settings.javaVersion = "21"

target(name: "clean") { java.clean() }
target(name: "build") { java.compileMain(); java.jar() }
